---
interface Props {
  title: string;
  excerpt: string;
  category: string;
  publishDate: string;
  readTime: string;
  slug: string;
  coverColor: string; // e.g. from-[#E8AFC7]/10 to-[#D9B8FF]/10
  svgPath: string; // decorative SVG icon path
}

const { title, excerpt, category, publishDate, readTime, slug, coverColor, svgPath } = Astro.props;
---

<article class="luxury-card flex flex-col justify-between h-full bg-white border border-border-main rounded-3xl overflow-hidden shadow-sm transition-all duration-300">
  <div>
    <!-- Cover Thumbnail -->
    <div class={`h-48 bg-gradient-to-tr ${coverColor} relative flex items-center justify-center p-6 border-b border-border-main/40`}>
      <div class="absolute inset-0 bg-[radial-gradient(#d9b8ff_1px,transparent_1px)] [background-size:20px_20px] opacity-10"></div>
      
      <!-- Calming SVG icon -->
      <svg class="h-20 w-20 text-brand-primary/60 drop-shadow-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        {svgPath ? (
          <path d={svgPath} />
        ) : (
          <!-- Default Feather / Wellness Symbol -->
          <path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z" />
        )}
      </svg>

      <!-- Category Tag -->
      <span class="absolute top-4 left-4 text-[10px] uppercase font-bold tracking-wider bg-white border border-border-main px-3 py-1 rounded-full text-brand-primary shadow-sm">
        {category}
      </span>
    </div>

    <!-- Blog Info -->
    <div class="p-6">
      <div class="flex items-center text-xs text-text-secondary mb-3 space-x-2.5">
        <span>{publishDate}</span>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-border-main"></span>
        <span>{readTime}</span>
      </div>

      <h3 class="font-heading font-semibold text-lg text-text-main mb-2.5 line-clamp-2 hover:text-brand-primary transition-colors">
        <a href={`/blog/${slug}`}>{title}</a>
      </h3>
      <p class="text-text-secondary text-sm leading-relaxed line-clamp-3 mb-4">{excerpt}</p>
    </div>
  </div>

  <!-- Read More Link -->
  <div class="p-6 pt-0">
    <a 
      href={`/blog/${slug}`} 
      class="group inline-flex items-center text-xs font-bold uppercase tracking-wider text-brand-primary hover:text-btn-hover transition-colors"
    >
      <span>Read Article</span>
      <svg class="h-4 w-4 ml-1.5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
