---
interface Props {
  englishName: string;
  sanskritName: string;
  difficulty: 'Beginner' | 'Intermediate' | 'Advanced';
  category: string;
  benefits: string[];
  description: string;
  svgPath: string; // inline SVG rendering fallback or custom design key
}

const { englishName, sanskritName, difficulty, category, benefits, description, svgPath } = Astro.props;

// Determine difficulty badge colors
const diffColors = {
  Beginner: 'bg-[#E3F2FD] text-[#0D47A1]',
  Intermediate: 'bg-[#FFF3E0] text-[#E65100]',
  Advanced: 'bg-[#F3E5F5] text-[#4A148C]'
};

const badgeColor = diffColors[difficulty] || 'bg-secondary-bg text-text-secondary';
---

<div class="luxury-card p-6 flex flex-col justify-between h-full bg-white border border-border-main rounded-3xl transition-all duration-300">
  <div>
    <!-- Pose Header Visual Representation -->
    <div class="relative w-full h-44 rounded-2xl bg-secondary-bg mb-5 flex items-center justify-center overflow-hidden border border-border-main/40">
      <div class="absolute inset-0 bg-radial-gradient from-brand-accent/20 via-transparent to-transparent opacity-60"></div>
      
      <!-- Styled Decorative Vector Representation for Pose -->
      <svg class="h-28 w-28 text-brand-primary/80 drop-shadow-md" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        {svgPath ? (
          <path d={svgPath} />
        ) : (
          <!-- Default Lotus Shape -->
          <path d="M12 2C11.5 5 9.5 8 6 8.5C7.5 10 7.5 12 7 13.5C8.5 13 10.5 13.5 12 16.5C13.5 13.5 15.5 13 17 13.5C16.5 12 16.5 10 18 8.5C14.5 8 12.5 5 12 2Z" fill="currentColor" opacity="0.6"/>
        )}
        <circle cx="12" cy="12" r="1" fill="currentColor" />
      </svg>

      <!-- Category Tag -->
      <span class="absolute top-3 left-3 text-[10px] uppercase font-bold tracking-wider bg-white border border-border-main px-2.5 py-1 rounded-full text-text-secondary shadow-sm">
        {category}
      </span>

      <!-- Difficulty Level Tag -->
      <span class={`absolute top-3 right-3 text-[10px] uppercase font-bold tracking-wider px-2.5 py-1 rounded-full shadow-sm ${badgeColor}`}>
        {difficulty}
      </span>
    </div>

    <!-- Titles -->
    <div class="space-y-1">
      <h3 class="font-heading font-semibold text-xl text-text-main tracking-tight leading-snug">{englishName}</h3>
      <p class="text-sm font-medium text-brand-primary italic font-heading">{sanskritName}</p>
    </div>

    <!-- Description -->
    <p class="text-text-secondary text-sm leading-relaxed mt-3.5 mb-5">{description}</p>
  </div>

  <!-- Benefits Section -->
  <div class="border-t border-border-main/50 pt-4">
    <h4 class="text-xs uppercase font-bold text-text-main tracking-wider mb-2.5">Key Benefits:</h4>
    <ul class="space-y-1.5">
      {benefits.map(benefit => (
        <li class="flex items-start text-xs text-text-secondary">
          <svg class="h-4 w-4 text-success-sage mr-1.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
          <span>{benefit}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
