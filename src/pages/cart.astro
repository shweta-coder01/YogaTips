        doc.text("Global Yoga Tips", pageWidth / 2, 30, { align: 'center' });
        
        doc.setFontSize(10);
        doc.setFont("helvetica", "normal");
        doc.setTextColor(100, 100, 100);
        doc.text("Premium Wellness Programs & Digital Downloads", pageWidth / 2, 38, { align: 'center' });
        
        // Invoice Title
        doc.setFontSize(20);
        doc.setTextColor(51, 51, 51);
        doc.text("INVOICE", 20, 60);
        
        // Details
        doc.setFontSize(11);
        doc.text(`Receipt Reference ID: ${orderDetailsCache.groupId}`, 20, 75);
        doc.text(`Date: ${new Date().toLocaleDateString()}`, 20, 82);
        doc.text(`Payment Gateway: simulated`, 20, 89);
        
        // Customer Details
        doc.text(`Billed To:`, 120, 75);
