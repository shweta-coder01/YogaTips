      // Generate text ticket file download
      function triggerFileDownload(name: string, id: string) {
        const content = `================================================
GLOBAL YOGA TIPS - DIGITAL PURCHASE TICKET
================================================

Thank you for your order! This file serves as your proof of purchase and download confirmation ticket.

Product Name:   ${name}
Reference ID:   ${id}
Delivery Date:  ${new Date().toLocaleString()}
Owner Account:  ${orderDetailsCache ? orderDetailsCache.buyerEmail : 'Practitioner'}

INSTRUCTIONS:
Your purchased guide is now fully unlocked. You can download the PDF files directly from your User Dashboard at www.globalyogatips.com/dashboard in the "Orders & Downloads" section.

For support, reach out via: support@globalyogatips.com
================================================`;
        
        const blob = new Blob([content], { type: 'text/plain' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${name.replace(/\s+/g, '_')}_Purchase_Ticket.txt`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      }

      // 9. PDF Invoice Download Trigger
