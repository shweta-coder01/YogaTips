        // Table Header
        doc.setDrawColor(220, 220, 220);
        doc.line(20, 105, pageWidth - 20, 105);
        doc.setFont("helvetica", "bold");
        doc.text("Description (Digital Download)", 20, 112);
        doc.text("Price", pageWidth - 50, 112);
        doc.line(20, 116, pageWidth - 20, 116);
        
        // Table Items
        doc.setFont("helvetica", "normal");
        let startY = 125;
        const curr = orderDetailsCache.currency;
        const sym = curr === 'INR' ? 'Rs.' : curr === 'GBP' ? 'GBP' : '$';
        
        orderDetailsCache.items.forEach((item: any) => {
          doc.text(item.product_name, 20, startY);
          doc.text(`${sym} ${parseFloat(item.amount).toFixed(2)}`, pageWidth - 50, startY);
          startY += 10;
        });

        // Totals
        const summaryY = startY + 10;
        doc.line(100, summaryY - 5, pageWidth - 20, summaryY - 5);
        
        doc.text("Subtotal:", 100, summaryY);
        doc.text(`${sym} ${parseFloat(orderDetailsCache.subtotal).toFixed(2)}`, pageWidth - 50, summaryY);

        if (orderDetailsCache.discount > 0) {
          doc.text("Discount:", 100, summaryY + 8);
          doc.text(`-${sym} ${parseFloat(orderDetailsCache.discount).toFixed(2)}`, pageWidth - 50, summaryY + 8);
        }

        doc.setFont("helvetica", "bold");
        doc.text("Total Paid:", 100, summaryY + 16);
        doc.text(`${sym} ${parseFloat(orderDetailsCache.total).toFixed(2)}`, pageWidth - 50, summaryY + 16);
        
        // Footer
        doc.setFont("helvetica", "normal");
        doc.setFontSize(9);
        doc.setTextColor(150, 150, 150);
        doc.text("This receipt constitutes proof of payment. Downloads are accessible permanently on your dashboard.", pageWidth / 2, 270, { align: 'center' });
        
        // Save PDF
        doc.save(`Invoice_Receipt_${orderDetailsCache.groupId}.pdf`);
      });

    });
  </script>
</Layout>

