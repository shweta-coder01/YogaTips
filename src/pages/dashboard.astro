---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard" description="Access your personal sanctuary dashboard. Update your profile, review order histories, and download purchased premium guides.">
  <!-- Loading state block overlay -->
  <div id="dashboard-loader" class="fixed inset-0 z-50 flex items-center justify-center bg-primary-bg">
    <div class="flex flex-col items-center space-y-4">
      <div class="w-12 h-12 border-4 border-brand-accent border-t-brand-primary rounded-full animate-spin"></div>
      <p class="text-xs uppercase font-bold text-text-secondary tracking-wider">Syncing Sanctuary Account...</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 min-h-[calc(100vh-20rem)]" id="dashboard-content">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- Left Sidebar Menu -->
      <aside class="lg:col-span-3 bg-white border border-border-main rounded-3xl p-5 shadow-sm space-y-6">
        <!-- User Info Header -->
        <div class="flex items-center space-x-3.5 pb-4 border-b border-border-main/50">
          <div class="h-12 w-12 bg-secondary-bg border border-border-main rounded-full flex items-center justify-center text-brand-primary">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
            </svg>
          </div>
          <div class="space-y-0.5 overflow-hidden">
            <h3 class="font-heading font-semibold text-text-main truncate" id="sidebar-user-name">Yoga Practitioner</h3>
            <p class="text-xs text-text-secondary truncate" id="sidebar-user-email">email@example.com</p>
          </div>
        </div>

        <!-- Tab Links -->
        <nav class="space-y-1">
          <button 
            type="button"
            id="tab-btn-downloads"
            class="tab-btn w-full text-left flex items-center space-x-3 px-4 py-3 rounded-2xl text-sm font-medium transition-all cursor-pointer"
            data-tab="downloads"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            <span>My Downloads</span>
          </button>
          <button 
            type="button"
            id="tab-btn-orders"
            class="tab-btn w-full text-left flex items-center space-x-3 px-4 py-3 rounded-2xl text-sm font-medium transition-all cursor-pointer"
            data-tab="orders"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
            <span>My Orders</span>
          </button>
          <button 
            type="button"
            id="tab-btn-profile"
            class="tab-btn w-full text-left flex items-center space-x-3 px-4 py-3 rounded-2xl text-sm font-medium transition-all cursor-pointer"
            data-tab="profile"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <span>Profile Settings</span>
          </button>
        </nav>
      </aside>

      <!-- Right Main Panel content -->
      <main class="lg:col-span-9 bg-white border border-border-main rounded-3xl p-6 sm:p-8 shadow-sm">
        
        <!-- 1. Downloads Tab -->
        <section id="tab-panel-downloads" class="tab-panel hidden space-y-6">
          <div class="border-b border-border-main/50 pb-4">
            <h2 class="font-heading font-semibold text-2xl text-text-main">My Downloads</h2>
            <p class="text-xs text-text-secondary mt-1">Access and download your purchased premium PDF wellness guides.</p>
          </div>

          <!-- Empty state downloads -->
          <div id="downloads-empty" class="hidden text-center py-16 space-y-5">
            <div class="h-16 w-16 bg-secondary-bg rounded-full flex items-center justify-center text-brand-primary mx-auto shadow-sm">
              <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </div>
            <div class="space-y-1">
              <h3 class="font-heading font-semibold text-lg text-text-main">No Downloads Available</h3>
              <p class="text-text-secondary text-sm max-w-sm mx-auto">You haven't purchased any premium programs yet. Start learning with our guided resources today!</p>
            </div>
            <a href="/programs" class="btn-primary py-2.5 px-6 text-xs shadow-sm">Shop Programs</a>
          </div>

          <!-- Downloads List Grid -->
          <div id="downloads-list" class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Dynamic elements will be inserted here client-side -->
          </div>
        </section>

        <!-- 2. Orders Tab -->
        <section id="tab-panel-orders" class="tab-panel hidden space-y-6">
          <div class="border-b border-border-main/50 pb-4">
            <h2 class="font-heading font-semibold text-2xl text-text-main">My Orders</h2>
            <p class="text-xs text-text-secondary mt-1">Review your checkout receipt log and billing transactions.</p>
          </div>

          <!-- Empty state orders -->
          <div id="orders-empty" class="hidden text-center py-16 space-y-5">
            <div class="h-16 w-16 bg-secondary-bg rounded-full flex items-center justify-center text-brand-primary mx-auto shadow-sm">
              <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
            <div class="space-y-1">
              <h3 class="font-heading font-semibold text-lg text-text-main">No Orders Placed</h3>
              <p class="text-text-secondary text-sm max-w-sm mx-auto">No transaction receipts found in your history. Buy a program guide to generate a receipt here.</p>
            </div>
            <a href="/programs" class="btn-primary py-2.5 px-6 text-xs shadow-sm">Shop Programs</a>
          </div>

          <!-- Orders List Table -->
          <div id="orders-table-container" class="overflow-x-auto border border-border-main/60 rounded-2xl hidden">
            <table class="min-w-full divide-y divide-border-main/40 text-left text-sm">
              <thead class="bg-secondary-bg/50 text-text-main font-heading font-semibold">
                <tr>
                  <th scope="col" class="px-6 py-4">Purchase Date</th>
                  <th scope="col" class="px-6 py-4">Product</th>
                  <th scope="col" class="px-6 py-4">Receipt ID</th>
                  <th scope="col" class="px-6 py-4">Amount</th>
                  <th scope="col" class="px-6 py-4">Status</th>
                </tr>
              </thead>
              <tbody id="orders-tbody" class="divide-y divide-border-main/20 text-text-secondary bg-white">
                <!-- Dynamic rows -->
              </tbody>
            </table>
          </div>
        </section>

        <!-- 3. Profile Tab -->
        <section id="tab-panel-profile" class="tab-panel hidden space-y-6">
          <div class="border-b border-border-main/50 pb-4">
            <h2 class="font-heading font-semibold text-2xl text-text-main">Profile Settings</h2>
            <p class="text-xs text-text-secondary mt-1">Manage your name and security credentials.</p>
          </div>

          <!-- Success Alert Profile -->
          <div id="profile-success" class="hidden bg-[#EEF8F3] border border-[#D5EFDF] text-success-sage text-xs font-semibold rounded-2xl p-4 flex items-center space-x-2">
            <svg class="h-5 w-5 text-success-sage shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            <span>Your profile details have been saved successfully!</span>
          </div>

          <!-- Profile Form -->
          <form id="profile-form" class="space-y-5 max-w-lg">
            <div class="space-y-1.5">
              <label for="profile-name" class="text-xs uppercase font-bold text-text-secondary tracking-wider">Full Name</label>
              <input 
                type="text" 
                id="profile-name" 
                required 
                class="w-full bg-primary-bg border border-border-main rounded-2xl py-3 px-4 text-sm text-text-main focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
              />
            </div>
            
            <div class="space-y-1.5">
              <label for="profile-email" class="text-xs uppercase font-bold text-text-secondary tracking-wider">Email Address</label>
              <input 
                type="email" 
                id="profile-email" 
                disabled 
                class="w-full bg-secondary-bg/85 border border-border-main rounded-2xl py-3 px-4 text-sm text-text-secondary cursor-not-allowed"
              />
              <p class="text-[10px] text-text-secondary/70">To change your email address, please contact support.</p>
            </div>

            <button type="submit" id="save-profile-btn" class="btn-primary py-3 px-8 text-sm cursor-pointer shadow-sm">
              Save Changes
            </button>
          </form>
        </section>

      </main>
    </div>
  </div>

  <!-- Client-side Dashboard Control Script -->
  <script>
    import { supabase } from '../lib/supabase.js';

    // File download mapper
    const productDownloads: Record<string, string> = {
      "Vinyasa Flow Daily Guide": "/downloads/vinyasa_guide.pdf",
      "Meditation & Mindfulness Guide": "/downloads/meditation_guide.pdf",
      "30-Day Yoga Challenge for Beginners": "/downloads/challenge_30day.pdf"
    };

    // Card Icon SVG builder
    const getCardIcon = (name: string) => {
      if (name.includes("Vinyasa")) {
        return `<path d="M12 4.5c-3 0-5 2-5.5 4.5 2.5.5 4.5 0 5.5-.5M12 12c-3 0-5 2-5.5 4.5 2.5.5 4.5 0 5.5-.5M12 4.5c3 0 5 2 5.5 4.5-2.5.5-4.5 0-5.5-.5M12 12c3 0 5 2 5.5 4.5-2.5.5-4.5 0-5.5-.5M12 1.5v21" />`;
      }
      if (name.includes("Meditation")) {
        return `<path d="M12 21a9 9 0 1 0-9-9 9 9 0 0 0 9 9zm0-18a7 7 0 1 1-7 7 7 7 0 0 1 7-7zm-1 3h2v5h-2zm0 7h2v2h-2z" />`;
      }
      return `<path d="M12 8v8M8 12h8M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.4 0-8-3.6-8-8s3.6-8 8-8 8 3.6 8 8-3.6 8-8 8z" />`;
    };

    document.addEventListener('DOMContentLoaded', async () => {
      // 1. Authenticate check
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/login';
        return;
      }

      const user = session.user;

      // 2. Load User Profile data
      let profileName = user.user_metadata?.name || 'Yoga Practitioner';
      
      const { data: profile } = await supabase
        .from('profiles')
        .select('*')
        .eq('id', user.id)
        .single();

      if (profile) {
        profileName = profile.name || profileName;
      }

      // Populate elements
      const nameHeader = document.getElementById('sidebar-user-name');
      const emailHeader = document.getElementById('sidebar-user-email');
      const inputName = document.getElementById('profile-name') as HTMLInputElement;
      const inputEmail = document.getElementById('profile-email') as HTMLInputElement;

      if (nameHeader) nameHeader.textContent = profileName;
      if (emailHeader) emailHeader.textContent = user.email || '';
      if (inputName) inputName.value = profileName;
      if (inputEmail) inputEmail.value = user.email || '';

      // 3. Load User Orders and Downloads
      const { data: orders } = await supabase
        .from('orders')
        .select('*')
        .eq('user_id', user.id);

      const completedOrders = (orders || []).filter(o => o.payment_status === 'completed');

      // Populate Orders Section
      const ordersEmpty = document.getElementById('orders-empty');
      const tableContainer = document.getElementById('orders-table-container');
      const tbody = document.getElementById('orders-tbody');

      if (completedOrders.length === 0) {
        ordersEmpty?.classList.remove('hidden');
      } else {
        tableContainer?.classList.remove('hidden');
        if (tbody) {
          tbody.innerHTML = completedOrders.map(order => `
            <tr class="hover:bg-secondary-bg/20 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap">${new Date(order.purchase_date).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}</td>
              <td class="px-6 py-4 font-semibold text-text-main">${order.product_name}</td>
              <td class="px-6 py-4 font-mono text-xs text-text-secondary/80">${order.id}</td>
              <td class="px-6 py-4 font-semibold text-text-main">$${parseFloat(order.amount).toFixed(2)}</td>
              <td class="px-6 py-4">
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-[#E8F8F0] text-success-sage">
                  Completed
                </span>
              </td>
            </tr>
          `).join('');
        }
      }

      // Populate Downloads Section
      const downloadsEmpty = document.getElementById('downloads-empty');
      const downloadsList = document.getElementById('downloads-list');

      if (completedOrders.length === 0) {
        downloadsEmpty?.classList.remove('hidden');
      } else {
        downloadsList?.classList.remove('hidden');
        
        // Map unique downloaded items (so if they bought the same item twice it only shows once)
        const uniqueProducts = Array.from(new Set(completedOrders.map(o => o.product_name)));
        
        if (downloadsList) {
          downloadsList.innerHTML = uniqueProducts.map(prodName => {
            const downloadUrl = productDownloads[prodName] || '#';
            const iconSvg = getCardIcon(prodName);

            return `
              <div class="bg-white border border-border-main p-6 rounded-2xl shadow-sm flex flex-col justify-between items-start space-y-4 hover:border-brand-primary/45 transition-colors duration-200">
                <div class="flex items-center space-x-3.5">
                  <div class="h-12 w-12 bg-secondary-bg rounded-xl flex items-center justify-center text-brand-primary shrink-0">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">${iconSvg}</svg>
                  </div>
                  <div>
                    <h3 class="font-heading font-semibold text-base text-text-main">${prodName}</h3>
                    <p class="text-xs text-text-secondary">Premium PDF Guide</p>
                  </div>
                </div>
                
                <a href="${downloadUrl}" download class="w-full btn-primary py-2.5 rounded-full text-xs font-semibold shadow-sm text-center flex items-center justify-center space-x-1.5 cursor-pointer">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                  <span>Download Guide</span>
                </a>
              </div>
            `;
          }).join('');
        }
      }

      // Hide Loader
      const loader = document.getElementById('dashboard-loader');
      if (loader) loader.classList.add('hidden');

      // 4. Tab Switching functionality
      const tabBtns = document.querySelectorAll('.tab-btn');
      const tabPanels = document.querySelectorAll('.tab-panel');

      const switchTab = (tabName: string) => {
        tabPanels.forEach(panel => panel.classList.add('hidden'));
        tabBtns.forEach(btn => {
          btn.classList.remove('bg-brand-primary/10', 'text-brand-primary');
          btn.classList.add('bg-white', 'text-text-main', 'hover:bg-secondary-bg');
        });

        const activePanel = document.getElementById(`tab-panel-${tabName}`);
        const activeBtn = document.getElementById(`tab-btn-${tabName}`);

        activePanel?.classList.remove('hidden');
        activeBtn?.classList.add('bg-brand-primary/10', 'text-brand-primary');
        activeBtn?.classList.remove('bg-white', 'text-text-main', 'hover:bg-secondary-bg');

        // Sync query param
        const url = new URL(window.location.href);
        url.searchParams.set('tab', tabName);
        window.history.pushState({}, '', url);
      };

      // Wire Tab Clicks
      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const tab = btn.getAttribute('data-tab') || 'downloads';
          switchTab(tab);
        });
      });

      // Initialize Active Tab from URL search params
      const urlParams = new URLSearchParams(window.location.search);
      const queryTab = urlParams.get('tab') || 'downloads';
      switchTab(queryTab);

      // 5. Update Profile Form
      const pForm = document.getElementById('profile-form');
      const pSuccess = document.getElementById('profile-success');
      const saveBtn = document.getElementById('save-profile-btn');

      pForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (saveBtn) {
          (saveBtn as HTMLButtonElement).disabled = true;
          saveBtn.textContent = 'Saving...';
        }
        pSuccess?.classList.add('hidden');

        const newName = (document.getElementById('profile-name') as HTMLInputElement).value.trim();

        // Update profile in supabase
        const { error } = await supabase
          .from('profiles')
          .update({ name: newName })
          .eq('id', user.id);

        if (error) {
          alert(`Failed to update profile: ${error.message}`);
        } else {
          // Update local elements
          if (nameHeader) nameHeader.textContent = newName;
          pSuccess?.classList.remove('hidden');
          setTimeout(() => {
            pSuccess?.classList.add('hidden');
          }, 5000);
        }

        if (saveBtn) {
          (saveBtn as HTMLButtonElement).disabled = false;
          saveBtn.textContent = 'Save Changes';
        }
      });
    });
  </script>
</Layout>
