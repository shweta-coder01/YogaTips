---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';

// Core blog posts database
const blogPosts = [
  {
    title: "5 Simple Yoga Poses to Ease Morning Stiffness",
    excerpt: "Start your day with gentle movement. These five beginner-friendly poses will stretch your spine, open your hips, and boost your energy for the day ahead.",
    category: "Poses",
    publishDate: "June 18, 2026",
    readTime: "5 min read",
    slug: "morning-stiffness-poses",
    coverColor: "from-[#FFF1F5] to-[#F5C2D7]/20",
    svgPath: "M12 3v3M12 18v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M3 12h3M18 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"
  },
  {
    title: "A Beginner's Guide to Mindfulness Meditation",
    excerpt: "Demystify meditation. Learn simple, step-by-step techniques to quiet your mind, focus on your breath, and establish a consistent, peaceful daily practice.",
    category: "Mindfulness",
    publishDate: "June 15, 2026",
    readTime: "7 min read",
    slug: "mindfulness-meditation-guide",
    coverColor: "from-[#FFF9FB] to-[#D9B8FF]/20",
    svgPath: "M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8zm1-13h-2v6h5v-2h-3z"
  },
  {
    title: "The Healing Power of Deep Restorative Sleep",
    excerpt: "Uncover the connection between quality rest and self-care. Discover simple evening yoga poses and breathing triggers that help cure insomnia naturally.",
    category: "Lifestyle",
    publishDate: "June 10, 2026",
    readTime: "6 min read",
    slug: "healing-restorative-sleep",
    coverColor: "from-[#FFF1F5] to-[#E8AFC7]/20",
    svgPath: "M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
  }
];

const categories = ["All", "Poses", "Mindfulness", "Lifestyle"];
---

<Layout title="Yoga Tips Blog" description="Browse our yoga and self-care blog. Explore articles on poses, mindfulness techniques, meditation, and healthy lifestyle tips.">
  <!-- Top Banner -->
  <section class="bg-gradient-to-b from-white to-secondary-bg/30 border-b border-border-main/40 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-4">
      <span class="text-xs uppercase font-bold text-brand-primary tracking-wider">Mindful Readings</span>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-semibold text-text-main">Yoga Tips Blog</h1>
      <p class="text-text-secondary text-base max-w-xl mx-auto">
        Your digital sanctuary for self-care advice, alignment breakdowns, meditation tips, and wellness wisdom.
      </p>
    </div>
  </section>

  <!-- Filter & Search Controls -->
  <section class="py-12 bg-white sticky top-20 z-40 shadow-sm border-b border-border-main/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-center">
        <!-- Search Input -->
        <div class="lg:col-span-4 relative">
          <label for="blog-search" class="sr-only">Search articles</label>
          <input 
            type="text" 
            id="blog-search" 
            placeholder="Search articles by title or keyword..." 
            class="w-full bg-primary-bg border border-border-main rounded-full py-3 px-5 pl-12 text-sm focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
          />
          <svg class="absolute left-4 top-3.5 h-4.5 w-4.5 text-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>

        <!-- Filters Grid -->
        <div class="lg:col-span-8 flex flex-wrap gap-4 items-center">
          <div class="flex items-center space-x-2.5">
            <span class="text-xs font-bold uppercase text-text-secondary tracking-wider">Category:</span>
            <div class="flex flex-wrap gap-2">
              {categories.map(cat => (
                <button 
                  type="button"
                  class={`blog-category-btn px-4 py-1.5 rounded-full text-xs font-medium border border-border-main transition-colors ${cat === 'All' ? 'bg-brand-primary border-brand-primary text-white' : 'bg-white hover:bg-secondary-bg text-text-main'}`}
                  data-category={cat}
                >
                  {cat}
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
      
      <!-- Live Counter -->
      <div class="text-xs text-text-secondary font-medium" id="blog-results-counter">
        Showing all {blogPosts.length} articles
      </div>
    </div>
  </section>

  <!-- Blog Grid Section -->
  <section class="py-16 bg-primary-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Empty state -->
      <div id="blog-empty-state" class="hidden text-center py-20 space-y-4">
        <svg class="h-16 w-16 text-brand-primary/50 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="font-heading font-semibold text-lg text-text-main">No Articles Found</h3>
        <p class="text-text-secondary text-sm max-w-xs mx-auto">We couldn't find any articles matching your search description. Try adjusting your filter tags.</p>
        <button id="blog-reset-btn" class="btn-secondary py-2 px-5 text-xs">Reset All Filters</button>
      </div>

      <!-- Main Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="blog-grid">
        {blogPosts.map(post => (
          <div 
            class="blog-card-wrapper transition-all duration-300"
            data-category={post.category}
            data-search-terms={`${post.title.toLowerCase()} ${post.excerpt.toLowerCase()}`}
          >
            <BlogCard {...post} />
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  let activeCategory = 'All';
  let searchQuery = '';

  const searchInput = document.getElementById('blog-search') as HTMLInputElement;
  const catBtns = document.querySelectorAll('.blog-category-btn');
  const cardWrappers = document.querySelectorAll('.blog-card-wrapper');
  const resultsCounter = document.getElementById('blog-results-counter');
  const emptyState = document.getElementById('blog-empty-state');
  const resetBtn = document.getElementById('blog-reset-btn');

  // Update button active UI
  const updateActiveButtonStyles = (buttons: NodeListOf<Element>, activeValue: string) => {
    buttons.forEach(btn => {
      const val = btn.getAttribute('data-category');
      if (val === activeValue) {
        btn.classList.add('bg-brand-primary', 'border-brand-primary', 'text-white');
        btn.classList.remove('bg-white', 'text-text-main', 'hover:bg-secondary-bg');
      } else {
        btn.classList.remove('bg-brand-primary', 'border-brand-primary', 'text-white');
        btn.classList.add('bg-white', 'text-text-main', 'hover:bg-secondary-bg');
      }
    });
  };

  // Filter Logic
  const applyFilters = () => {
    let visibleCount = 0;

    cardWrappers.forEach(card => {
      const wrapper = card as HTMLElement;
      const cardCat = wrapper.dataset.category || '';
      const searchTerms = wrapper.dataset.searchTerms || '';

      const matchesCat = activeCategory === 'All' || cardCat === activeCategory;
      const matchesSearch = searchQuery === '' || searchTerms.includes(searchQuery);

      if (matchesCat && matchesSearch) {
        wrapper.style.display = 'block';
        wrapper.style.opacity = '1';
        wrapper.style.transform = 'scale(1)';
        visibleCount++;
      } else {
        wrapper.style.display = 'none';
        wrapper.style.opacity = '0';
        wrapper.style.transform = 'scale(0.95)';
      }
    });

    // Update Counter text
    if (resultsCounter) {
      resultsCounter.textContent = searchQuery || activeCategory !== 'All'
        ? `Found ${visibleCount} matching articles`
        : `Showing all ${cardWrappers.length} articles`;
    }

    // Toggle Empty State UI
    if (emptyState) {
      if (visibleCount === 0) {
        emptyState.classList.remove('hidden');
      } else {
        emptyState.classList.add('hidden');
      }
    }
  };

  // Wire Category Events
  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeCategory = btn.getAttribute('data-category') || 'All';
      updateActiveButtonStyles(catBtns, activeCategory);
      applyFilters();
    });
  });

  // Wire Search Events
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      searchQuery = (e.target as HTMLInputElement).value.trim().toLowerCase();
      applyFilters();
    });
  }

  // Reset Events
  if (resetBtn) {
    resetBtn.addEventListener('click', () => {
      activeCategory = 'All';
      searchQuery = '';
      if (searchInput) searchInput.value = '';
      updateActiveButtonStyles(catBtns, 'All');
      applyFilters();
    });
  }
</script>
