---
import Layout from '../layouts/Layout.astro';
import ProgramCard from '../components/ProgramCard.astro';

// Premium downloadable products
const programs = [
  {
    id: "vinyasa_guide",
    name: "Vinyasa Flow Daily Guide",
    price: 19,
    description: "A complete daily printable guide designed to guide you through morning Vinyasa flows. Strengthen muscles, restore spinal mobility, and establish consistency.",
    features: [
      "Full 38 pages downloadable PDF guide",
      "Sanskrit-English alignment breakdown",
      "Printable daily practice sheets",
      "Breathing and Pranayama exercises"
    ],
    coverSvg: "M12 4.5c-3 0-5 2-5.5 4.5 2.5.5 4.5 0 5.5-.5M12 12c-3 0-5 2-5.5 4.5 2.5.5 4.5 0 5.5-.5M12 4.5c3 0 5 2 5.5 4.5-2.5.5-4.5 0-5.5-.5M12 12c3 0 5 2 5.5 4.5-2.5.5-4.5 0-5.5-.5M12 1.5v21",
    coverImage: "images/programs/vinyasa_flow_guide.png"
  },
  {
    id: "meditation_guide",
    name: "Meditation & Mindfulness Guide",
    price: 12,
    description: "Our core mindfulness blueprint. Demystify mental quietude with gentle breathing exercises, body scans, and emotional composure templates.",
    features: [
      "Restorative 24-page PDF handbook",
      "7-Day morning meditation calendar",
      "Journal prompts for self-reflection",
      "Scientific stress relief guidelines"
    ],
    coverSvg: "M12 21a9 9 0 1 0-9-9 9 9 0 0 0 9 9zm0-18a7 7 0 1 1-7 7 7 7 0 0 1 7-7zm-1 3h2v5h-2zm0 7h2v2h-2z",
    coverImage: "images/programs/meditation_mindfulness_guide.png"
  },
  {
    id: "challenge_30day",
    name: "30-Day Yoga Challenge for Beginners",
    price: 25,
    description: "The ultimate progressive beginner program. Transition step-by-step from foundational postures to elegant daily flows with ease.",
    features: [
      "Comprehensive 50 pages PDF coursebook",
      "30-Day progressive flow calendar",
      "Video posture reference index links",
      "Pose adaptation and block-use guide"
    ],
    coverSvg: "M12 8v8M8 12h8M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.4 0-8-3.6-8-8s3.6-8 8-8 8 3.6 8 8-3.6 8-8 8z",
    coverImage: "images/programs/30_day_yoga_challenge.png"
  }
];
---

<Layout title="Premium Yoga Programs" description="Shop our digital wellness downloads and premium yoga programs. Secure checkout via Razorpay with instant PDF delivery.">
  <!-- Top Banner -->
  <section class="bg-gradient-to-b from-white to-secondary-bg/30 border-b border-border-main/40 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-4">
      <span class="text-xs uppercase font-bold text-brand-primary tracking-wider">Wellness Storefront</span>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-semibold text-text-main">Premium Yoga Programs</h1>
      <p class="text-text-secondary text-base max-w-xl mx-auto">
        Invest in your practice. Downloadable PDF guides, calendars, and templates with lifetime access and instant delivery.
      </p>
    </div>
  </section>

  <!-- Programs Grid -->
  <section class="py-16 bg-primary-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {programs.map(prog => (
          <ProgramCard {...prog} />
        ))}
      </div>
    </div>
  </section>

  <!-- Mock Payment Gateway Modal Overlay -->
  <div id="mock-payment-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm hidden">
    <div class="bg-white rounded-3xl border border-border-main p-8 max-w-md w-full mx-4 shadow-2xl relative space-y-6 animate-in fade-in zoom-in-95 duration-200">
      <!-- Modal Header -->
      <div class="flex justify-between items-start">
        <div class="space-y-1">
          <div class="text-[10px] uppercase font-bold text-brand-primary tracking-wider flex items-center">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-primary mr-1.5 animate-pulse"></span>
            Mock Payment Gateway
          </div>
          <h3 class="font-heading font-semibold text-xl text-text-main" id="modal-product-name">Product Name</h3>
        </div>
        <button id="close-modal-btn" class="p-1 rounded-full text-text-secondary hover:bg-secondary-bg transition-colors cursor-pointer">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Price summary -->
      <div class="bg-secondary-bg/55 border border-border-main/50 rounded-2xl p-4 flex justify-between items-center">
        <span class="text-sm text-text-secondary">Amount Due:</span>
        <span class="font-heading font-bold text-lg text-text-main" id="modal-product-price">$0.00</span>
      </div>

      <!-- Payment Form Content -->
      <form id="mock-payment-form" class="space-y-4">
        <div class="space-y-1">
          <label for="mock-card-number" class="text-xs uppercase font-bold text-text-secondary tracking-wider">Card Number</label>
          <input 
            type="text" 
            id="mock-card-number" 
            placeholder="4111 2222 3333 4444" 
            maxlength="19" 
            required 
            class="w-full bg-primary-bg border border-border-main rounded-xl py-3 px-4 text-sm text-text-main focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
          />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-1">
            <label for="mock-expiry" class="text-xs uppercase font-bold text-text-secondary tracking-wider">Expiry Date</label>
            <input 
              type="text" 
              id="mock-expiry" 
              placeholder="MM/YY" 
              maxlength="5" 
              required 
              class="w-full bg-primary-bg border border-border-main rounded-xl py-3 px-4 text-sm text-text-main focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
            />
          </div>
          <div class="space-y-1">
            <label for="mock-cvv" class="text-xs uppercase font-bold text-text-secondary tracking-wider">CVV</label>
            <input 
              type="password" 
              id="mock-cvv" 
              placeholder="•••" 
              maxlength="3" 
              required 
              class="w-full bg-primary-bg border border-border-main rounded-xl py-3 px-4 text-sm text-text-main focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
            />
          </div>
        </div>

        <button type="submit" id="submit-payment-btn" class="w-full btn-primary py-3.5 rounded-full text-sm font-semibold tracking-wider flex items-center justify-center space-x-2 mt-4 cursor-pointer">
          <svg class="h-4.5 w-4.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          <span id="payment-btn-text">Pay Securely</span>
        </button>
      </form>

      <!-- Processing State -->
      <div id="payment-processing-state" class="hidden flex flex-col items-center justify-center py-10 space-y-4">
        <!-- Spinner -->
        <div class="w-16 h-16 border-4 border-brand-accent border-t-brand-primary rounded-full animate-spin"></div>
        <h4 class="font-heading font-semibold text-text-main">Verifying Transaction...</h4>
        <p class="text-xs text-text-secondary text-center max-w-xs">Connecting to secure gateway. Please do not close this window or refresh the page.</p>
      </div>

      <!-- Success State -->
      <div id="payment-success-state" class="hidden flex flex-col items-center justify-center py-10 space-y-4 text-center">
        <div class="w-16 h-16 bg-success-sage/20 text-success-sage rounded-full flex items-center justify-center">
          <svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h4 class="font-heading font-semibold text-xl text-text-main">Payment Successful!</h4>
        <p class="text-sm text-text-secondary max-w-xs">Your purchase is complete. Redirecting you to your downloads area to access your PDF...</p>
      </div>
    </div>
  </div>

  <!-- Load Razorpay Library -->
  <script src="https://checkout.razorpay.com/v1/checkout.js" is:inline></script>

  <!-- Client Purchase Handling Logic -->
  <script>
    import { supabase } from '../lib/supabase.js';

    // UI elements
    const checkoutBtns = document.querySelectorAll('.checkout-btn');
    
    // Modal elements
    const modal = document.getElementById('mock-payment-modal');
    const closeBtn = document.getElementById('close-modal-btn');
    const modalProdName = document.getElementById('modal-product-name');
    const modalProdPrice = document.getElementById('modal-product-price');
    const paymentForm = document.getElementById('mock-payment-form');
    const processingState = document.getElementById('payment-processing-state');
    const successState = document.getElementById('payment-success-state');
    const submitBtn = document.getElementById('submit-payment-btn');
    const btnText = document.getElementById('payment-btn-text');

    // Input elements for card formatting helper
    const cardInput = document.getElementById('mock-card-number') as HTMLInputElement;
    const expiryInput = document.getElementById('mock-expiry') as HTMLInputElement;

    // Active product data holder
    let selectedProduct = { id: '', name: '', price: 0 };

    // Format card number with spaces
    if (cardInput) {
      cardInput.addEventListener('input', (e) => {
        let value = (e.target as HTMLInputElement).value.replace(/\s+/g, '').replace(/[^0-9]/gi, '');
        let formatted = '';
        for (let i = 0; i < value.length; i++) {
          if (i > 0 && i % 4 === 0) formatted += ' ';
          formatted += value[i];
        }
        (e.target as HTMLInputElement).value = formatted;
      });
    }

    // Format expiry date with slash
    if (expiryInput) {
      expiryInput.addEventListener('input', (e) => {
        let value = (e.target as HTMLInputElement).value.replace(/\s+/g, '').replace(/[^0-9]/gi, '');
        if (value.length > 2) {
          (e.target as HTMLInputElement).value = value.substring(0, 2) + '/' + value.substring(2, 4);
        } else {
          (e.target as HTMLInputElement).value = value;
        }
      });
    }

    // Handle Buy Button Clicks
    checkoutBtns.forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id') || '';
        const name = btn.getAttribute('data-name') || '';
        const price = parseFloat(btn.getAttribute('data-price') || '0');

        selectedProduct = { id, name, price };

        // 1. Verify User Login State
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) {
          // If not logged in, redirect to login page with dynamic query redirect back here
          window.location.href = `/login?redirect=programs`;
          return;
        }

        // 2. Determine gateway (Mock vs Razorpay)
        const rzpKey = (window as any).PUBLIC_RAZORPAY_KEY_ID || import.meta.env.PUBLIC_RAZORPAY_KEY_ID || '';
        
        if (rzpKey) {
          // Launch real Razorpay Checkout Standard Integration
          const options = {
            key: rzpKey,
            amount: price * 100, // paise
            currency: "USD",
            name: "Global Yoga Tips",
            description: name,
            image: "https://globalyogatips.com/favicon.svg",
            handler: async function (response: any) {
              // Payment Successful via Razorpay
              const paymentId = response.razorpay_payment_id;
              
              // Register order in database
              const { error } = await supabase.from('orders').insert({
                id: paymentId,
                user_id: session.user.id,
                product_name: name,
                amount: price,
                payment_status: 'completed'
              });

              if (error) {
                alert(`Order recorded locally but database sync failed: ${error.message}`);
              }
              
              // Redirect to downloads tab on dashboard
              window.location.href = '/dashboard?tab=downloads';
            },
            prefill: {
              name: session.user.user_metadata?.name || '',
              email: session.user.email || ''
            },
            theme: {
              color: "#E8AFC7" // dusty rose pink logo accent
            }
          };
          const rzp = new (window as any).Razorpay(options);
          rzp.open();
        } else {
          // Launch custom Mock Payment Modal
          if (modal) {
            modalProdName.textContent = name;
            modalProdPrice.textContent = `$${price.toFixed(2)}`;
            
            // Show modal, reset form states
            modal.classList.remove('hidden');
            paymentForm?.classList.remove('hidden');
            processingState?.classList.add('hidden');
            successState?.classList.add('hidden');
            if (submitBtn) (submitBtn as HTMLButtonElement).disabled = false;
            if (btnText) btnText.textContent = 'Pay Securely';
          }
        }
      });
    });

    // Close Modal Events
    const closeModal = () => {
      modal?.classList.add('hidden');
    };
    closeBtn?.addEventListener('click', closeModal);
    
    // Close modal on background click
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    // Handle Mock Payment Form Submission
    paymentForm?.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Show processing spinner
      paymentForm.classList.add('hidden');
      processingState?.classList.remove('hidden');
      
      // Simulate gateway delay (1.5 seconds)
      setTimeout(async () => {
        // Record order in database
        const { data: { session } } = await supabase.auth.getSession();
        if (session) {
          const mockPaymentId = 'pay_mock_' + Math.random().toString(36).substring(2, 11);
          
          await supabase.from('orders').insert({
            id: mockPaymentId,
            user_id: session.user.id,
            product_name: selectedProduct.name,
            amount: selectedProduct.price,
            payment_status: 'completed'
          });
        }

        // Show Success Checkmark
        processingState?.classList.add('hidden');
        successState?.classList.remove('hidden');

        // Redirect to dashboard downloads tab after 2 seconds
        setTimeout(() => {
          window.location.href = '/dashboard?tab=downloads';
        }, 2200);
      }, 1500);
    });
  </script>
</Layout>
