---

<Layout title="Premium Yoga Programs" description="Shop our digital wellness downloads and premium yoga programs. Secure checkout via Razorpay with instant PDF delivery.">
  <!-- Top Banner -->
  <section class="bg-gradient-to-b from-white to-secondary-bg/30 border-b border-border-main/40 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-4">
      <span class="text-xs uppercase font-bold text-brand-primary tracking-wider">Wellness Storefront</span>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-semibold text-text-main">Premium Yoga Programs</h1>
      <p class="text-text-secondary text-base max-w-xl mx-auto">
        Invest in your practice. Downloadable PDF guides, calendars, and templates with lifetime access and instant delivery.
      </p>
    </div>
  </section>

  <!-- Programs Grid -->
  <section class="py-16 bg-primary-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {programs.map(prog => (
          <ProgramCard {...prog} />
        ))}
      </div>
    </div>
  </section>

  <!-- Removed mock payment modal, moved to cart page -->

  <!-- Client Add to Cart Logic -->
  <script>
    const addToCartBtns = document.querySelectorAll('.add-to-cart-btn');

    addToCartBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id') || '';
        const name = btn.getAttribute('data-name') || '';
        const price = parseFloat(btn.getAttribute('data-price') || '0');

        const product = { id, name, price };

        // Load existing cart
        const cartStr = localStorage.getItem('yoga_cart');
        const cart = cartStr ? JSON.parse(cartStr) : [];

        // Check if item already exists to prevent duplicate downloads (optional)
        const exists = cart.find((item: any) => item.id === product.id);
        if (!exists) {
          cart.push(product);
          localStorage.setItem('yoga_cart', JSON.stringify(cart));
          window.dispatchEvent(new Event('cart-updated'));
        }

        // Visual feedback
        const originalText = btn.querySelector('span')?.textContent;
        const span = btn.querySelector('span');
        if (span) {
          span.textContent = 'Added!';
          btn.classList.add('bg-success-sage', 'text-white', 'border-success-sage');
          btn.classList.remove('btn-primary');
          
          setTimeout(() => {
            span.textContent = originalText || 'Add to Cart';
            btn.classList.remove('bg-success-sage', 'text-white', 'border-success-sage');
            btn.classList.add('btn-primary');
          }, 1500);
        }
      });
    });
  </script>
</Layout>
