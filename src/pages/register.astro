---
import Layout from '../layouts/Layout.astro';
const basePath = import.meta.env.BASE_URL;
---

<Layout title="Create Your Sanctuary Account" description="Register a new account on Global Yoga Tips to begin your yoga journey and buy premium wellness guides.">
  <section class="py-20 bg-primary-bg min-h-[calc(100vh-22rem)] flex items-center justify-center">
    <div class="max-w-md w-full mx-4">
      <div class="bg-white border border-border-main rounded-3xl p-8 sm:p-10 shadow-md space-y-6 relative overflow-hidden">
        
        <!-- Mock Mode Notice Badge -->
        <div id="mock-auth-badge" class="hidden bg-secondary-bg border border-brand-primary/20 rounded-full py-1 px-3 text-[10px] font-bold text-brand-primary tracking-wider uppercase text-center">
          ⚡ Offline Sandbox Mode Enabled
        </div>

        <div class="text-center space-y-2">
          <h1 class="text-2xl sm:text-3xl font-heading font-semibold text-text-main">Create Account</h1>
          <p class="text-text-secondary text-sm">Join our global community of yoga practitioners.</p>
        </div>

        <!-- Error Alert box -->
        <div id="error-alert" class="hidden bg-[#FDF2F2] border border-[#FDE8E8] text-[#E53E3E] text-xs font-semibold rounded-2xl p-4 flex items-start space-x-2.5">
          <svg class="h-4.5 w-4.5 shrink-0" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          <span id="error-message">Registration failed.</span>
        </div>

        <!-- Verification Pending Alert Box -->
        <div id="verification-pending-box" class="hidden text-center py-6 space-y-6">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-brand-primary/10 text-brand-primary rounded-full">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div class="space-y-2">
            <h3 class="font-heading font-semibold text-xl text-text-main">Verify Your Email</h3>
            <p class="text-xs text-text-secondary max-w-sm mx-auto leading-relaxed">
              We've sent a verification link to <strong id="verification-email-text" class="text-text-main"></strong>. Please check your inbox and click the link to confirm your account, then you can log in to place your order.
            </p>
          </div>
          <div class="pt-2">
            <a id="go-to-login-btn" href={`${basePath}login`} class="btn-primary py-2.5 px-6 text-sm text-center inline-block">Go to Login Page</a>
          </div>
        </div>

        <!-- Form -->
        <form id="register-form" class="space-y-4">
          <!-- Name -->
          <div class="space-y-1.5">
            <label for="name" class="text-xs uppercase font-bold text-text-secondary tracking-wider">Full Name</label>
            <input 
              type="text" 
              id="name" 
              required 
              placeholder="Elena Vance" 
              class="w-full bg-primary-bg border border-border-main rounded-2xl py-3 px-4 text-sm text-text-main focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
            />
          </div>

          <!-- Email or Phone -->
          <div class="space-y-1.5">
            <label for="emailOrPhone" class="text-xs uppercase font-bold text-text-secondary tracking-wider">Email or Phone Number</label>
            <input 
              type="text" 
              id="emailOrPhone" 
              required 
              placeholder="name@example.com or +1234567890" 
              class="w-full bg-primary-bg border border-border-main rounded-2xl py-3 px-4 text-sm text-text-main focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
            />
          </div>

          <!-- Password -->
          <div class="space-y-1.5 relative">
            <label for="password" class="text-xs uppercase font-bold text-text-secondary tracking-wider">Password</label>
            <div class="relative">
              <input 
                type="password" 
                id="password" 
                required 
                placeholder="••••••••" 
                minlength="6"
                class="w-full bg-primary-bg border border-border-main rounded-2xl py-3 px-4 text-sm text-text-main focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
              />
            </div>
          </div>

          <!-- Confirm Password -->
          <div class="space-y-1.5 relative">
            <label for="confirm-password" class="text-xs uppercase font-bold text-text-secondary tracking-wider">Confirm Password</label>
            <div class="relative">
              <input 
                type="password" 
                id="confirm-password" 
                required 
                placeholder="••••••••" 
                minlength="6"
                class="w-full bg-primary-bg border border-border-main rounded-2xl py-3 px-4 text-sm text-text-main focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
              />
            </div>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit" 
            id="submit-btn"
            class="w-full btn-primary py-3.5 rounded-full text-sm font-semibold tracking-wider flex items-center justify-center space-x-2 mt-6 cursor-pointer shadow-sm"
          >
            <span>Register Account</span>
            <svg class="h-4.5 w-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
          </button>
        </form>

        <div class="border-t border-border-main/50 pt-4 text-center">
          <p class="text-xs text-text-secondary">
            Already have an account? 
            <a href={`${basePath}login`} class="font-bold text-brand-primary hover:text-btn-hover transition-colors">Log in here</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Client-side Logic -->
  <script>
    import { supabase, isMockMode } from '../lib/supabase.js';

    // Show mock sandbox badge if applicable
    const mockBadge = document.getElementById('mock-auth-badge');
    if (isMockMode && mockBadge) {
      mockBadge.classList.remove('hidden');
    }

    const regForm = document.getElementById('register-form');
    const errorAlert = document.getElementById('error-alert');
    const errorMsg = document.getElementById('error-message');
    const submitBtn = document.getElementById('submit-btn');

    regForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const name = (document.getElementById('name') as HTMLInputElement).value.trim();
      const emailOrPhone = (document.getElementById('emailOrPhone') as HTMLInputElement).value.trim();
      const password = (document.getElementById('password') as HTMLInputElement).value;
      const confirmPassword = (document.getElementById('confirm-password') as HTMLInputElement).value;

      const isEmail = emailOrPhone.includes('@');
      const email = isEmail ? emailOrPhone : undefined;
      const phone = !isEmail ? emailOrPhone : undefined;

      errorAlert?.classList.add('hidden');

      // 1. Client-side Passwords Match Validation
      if (password !== confirmPassword) {
        if (errorMsg) errorMsg.textContent = "Passwords do not match. Please verify.";
        errorAlert?.classList.remove('hidden');
        return;
      }

      if (submitBtn) {
        (submitBtn as HTMLButtonElement).disabled = true;
        submitBtn.querySelector('span')!.textContent = 'Creating account...';
      }

      // 2. Register via Supabase Client Auth
      const { data, error } = await supabase.auth.signUp({
        email,
        phone,
        password,
        options: {
          data: {
            name: name
          }
        }
      });

      if (error) {
        if (errorMsg) errorMsg.textContent = error.message;
        errorAlert?.classList.remove('hidden');
        if (submitBtn) {
          (submitBtn as HTMLButtonElement).disabled = false;
          submitBtn.querySelector('span')!.textContent = 'Register Account';
        }
      } else {
        // Send Welcome email (guest/user registration confirmation) in background
        if (email) {
          sendWelcomeEmail(email, name);
        }

        // If a session does not exist (meaning email confirmation is required by Supabase)
        if (!data.session) {
          const form = document.getElementById('register-form');
          const headerTitle = document.querySelector('.text-center h1');
          const headerDesc = document.querySelector('.text-center p');
          const verificationBox = document.getElementById('verification-pending-box');
          const emailText = document.getElementById('verification-email-text');
          const goToLoginBtn = document.getElementById('go-to-login-btn') as HTMLAnchorElement;
          
          if (emailText) emailText.textContent = email || '';
          
          const basePath = document.body.dataset.baseUrl || '/';
          const urlParams = new URLSearchParams(window.location.search);
          const redirect = urlParams.get('redirect');
          if (goToLoginBtn && redirect) {
            goToLoginBtn.href = `${basePath}login?redirect=${redirect}`;
          }

          form?.classList.add('hidden');
          headerTitle?.classList.add('hidden');
          headerDesc?.classList.add('hidden');
          verificationBox?.classList.remove('hidden');
        } else {
          // Successful registration (automatic login enabled). Redirect back to checkout or dashboard
          const basePath = document.body.dataset.baseUrl || '/';
          const urlParams = new URLSearchParams(window.location.search);
          const redirect = urlParams.get('redirect');
          if (redirect) {
            window.location.href = `${basePath}${redirect}`;
          } else {
            window.location.href = `${basePath}dashboard`;
          }
        }
      }
    });

    async function sendWelcomeEmail(email: string, name: string) {
      const emailContentText = `
================================================
GLOBAL YOGA TIPS - WELCOME TO YOUR SANCTUARY
================================================
To:          ${email}
Name:        ${name || 'Valued Practitioner'}
Date:        ${new Date().toLocaleString()}

Welcome to Global Yoga Tips! Your account has been registered successfully.
You can now access your profile, track purchases, and download premium yoga guides at any time.

Log in here: https://www.globalyogatips.com/login

For support, contact us at: support@globalyogatips.com
================================================`;

      console.log("================================================");
      console.log("SENDING WELCOME EMAIL VIA RESEND...");
      console.log(emailContentText);
      console.log("================================================");

      const serviceId = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID || '';
      const templateId = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID || '';
      const publicKey = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY || '';

      if (serviceId && templateId && publicKey) {
        try {
          const htmlBody = `
            <div style="font-family: sans-serif; padding: 20px; color: #1a1a1a; max-width: 600px; margin: 0 auto; border: 1px solid #eaeaea; border-radius: 12px;">
              <h2 style="color: #c4829e; font-weight: bold; border-bottom: 2px solid #eaeaea; padding-bottom: 10px;">WELCOME TO GLOBAL YOGA TIPS</h2>
              <p>Hello <strong>${name || 'Practitioner'}</strong>,</p>
              <p>Welcome to Global Yoga Tips! Your account has been registered successfully.</p>
              <p>You can now manage your practitioner profile, view purchases, and download premium yoga guides at any time.</p>
              
              <div style="text-align: center; margin: 30px 0;">
                <a href="https://www.globalyogatips.com/login" style="background-color: #c4829e; color: white; padding: 12px 25px; text-decoration: none; border-radius: 25px; font-weight: bold; display: inline-block;">Log In to Your Sanctuary</a>
              </div>

              <p style="margin-top: 30px; font-size: 11px; color: #888888; border-top: 1px solid #eaeaea; padding-top: 15px; text-align: center;">
                If you have any questions, reply to this email or contact support@globalyogatips.com.
              </p>
            </div>
          `;

          const response = await fetch('https://api.emailjs.com/api/v1.0/email/send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              service_id: serviceId,
              template_id: templateId,
              user_id: publicKey,
              template_params: {
                subject: "Welcome to Global Yoga Tips!",
                message: htmlBody,
                to_email: email
              }
            })
          });

          if (response.ok) {
            console.log("EmailJS welcome email sent successfully!");
          } else {
            const errorText = await response.text();
            console.error("EmailJS welcome sending failed:", errorText);
            alert("Welcome Email Delivery Failure: " + errorText);
          }
        } catch (err: any) {
          console.error("Failed to connect to EmailJS for welcome email:", err);
          alert("Welcome Email Connection Error: " + err.message);
        }
      } else {
        console.warn("EmailJS credentials not configured in .env. Skipping welcome email dispatch.");
      }
    }
  </script>
</Layout>
