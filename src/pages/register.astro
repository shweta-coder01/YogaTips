---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Create Your Sanctuary Account" description="Register a new account on Global Yoga Tips to begin your yoga journey and buy premium wellness guides.">
  <section class="py-20 bg-primary-bg min-h-[calc(100vh-22rem)] flex items-center justify-center">
    <div class="max-w-md w-full mx-4">
      <div class="bg-white border border-border-main rounded-3xl p-8 sm:p-10 shadow-md space-y-6 relative overflow-hidden">
        
        <!-- Mock Mode Notice Badge -->
        <div id="mock-auth-badge" class="hidden bg-secondary-bg border border-brand-primary/20 rounded-full py-1 px-3 text-[10px] font-bold text-brand-primary tracking-wider uppercase text-center">
          ⚡ Offline Sandbox Mode Enabled
        </div>

        <div class="text-center space-y-2">
          <h1 class="text-2xl sm:text-3xl font-heading font-semibold text-text-main">Create Account</h1>
          <p class="text-text-secondary text-sm">Join our global community of yoga practitioners.</p>
        </div>

        <!-- Error Alert box -->
        <div id="error-alert" class="hidden bg-[#FDF2F2] border border-[#FDE8E8] text-[#E53E3E] text-xs font-semibold rounded-2xl p-4 flex items-start space-x-2.5">
          <svg class="h-4.5 w-4.5 shrink-0" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          <span id="error-message">Registration failed.</span>
        </div>

        <!-- Form -->
        <form id="register-form" class="space-y-4">
          <!-- Name -->
          <div class="space-y-1.5">
            <label for="name" class="text-xs uppercase font-bold text-text-secondary tracking-wider">Full Name</label>
            <input 
              type="text" 
              id="name" 
              required 
              placeholder="Elena Vance" 
              class="w-full bg-primary-bg border border-border-main rounded-2xl py-3 px-4 text-sm text-text-main focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
            />
          </div>

          <!-- Email -->
          <div class="space-y-1.5">
            <label for="email" class="text-xs uppercase font-bold text-text-secondary tracking-wider">Email Address</label>
            <input 
              type="email" 
              id="email" 
              required 
              placeholder="name@example.com" 
              class="w-full bg-primary-bg border border-border-main rounded-2xl py-3 px-4 text-sm text-text-main focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
            />
          </div>

          <!-- Password -->
          <div class="space-y-1.5 relative">
            <label for="password" class="text-xs uppercase font-bold text-text-secondary tracking-wider">Password</label>
            <div class="relative">
              <input 
                type="password" 
                id="password" 
                required 
                placeholder="••••••••" 
                minlength="6"
                class="w-full bg-primary-bg border border-border-main rounded-2xl py-3 px-4 text-sm text-text-main focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
              />
            </div>
          </div>

          <!-- Confirm Password -->
          <div class="space-y-1.5 relative">
            <label for="confirm-password" class="text-xs uppercase font-bold text-text-secondary tracking-wider">Confirm Password</label>
            <div class="relative">
              <input 
                type="password" 
                id="confirm-password" 
                required 
                placeholder="••••••••" 
                minlength="6"
                class="w-full bg-primary-bg border border-border-main rounded-2xl py-3 px-4 text-sm text-text-main focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
              />
            </div>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit" 
            id="submit-btn"
            class="w-full btn-primary py-3.5 rounded-full text-sm font-semibold tracking-wider flex items-center justify-center space-x-2 mt-6 cursor-pointer shadow-sm"
          >
            <span>Register Account</span>
            <svg class="h-4.5 w-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
          </button>
        </form>

        <div class="border-t border-border-main/50 pt-4 text-center">
          <p class="text-xs text-text-secondary">
            Already have an account? 
            <a href="/login" class="font-bold text-brand-primary hover:text-btn-hover transition-colors">Log in here</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Client-side Logic -->
  <script>
    import { supabase, isMockMode } from '../lib/supabase.js';

    // Show mock sandbox badge if applicable
    const mockBadge = document.getElementById('mock-auth-badge');
    if (isMockMode && mockBadge) {
      mockBadge.classList.remove('hidden');
    }

    const regForm = document.getElementById('register-form');
    const errorAlert = document.getElementById('error-alert');
    const errorMsg = document.getElementById('error-message');
    const submitBtn = document.getElementById('submit-btn');

    regForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const name = (document.getElementById('name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('email') as HTMLInputElement).value.trim();
      const password = (document.getElementById('password') as HTMLInputElement).value;
      const confirmPassword = (document.getElementById('confirm-password') as HTMLInputElement).value;

      errorAlert?.classList.add('hidden');

      // 1. Client-side Passwords Match Validation
      if (password !== confirmPassword) {
        if (errorMsg) errorMsg.textContent = "Passwords do not match. Please verify.";
        errorAlert?.classList.remove('hidden');
        return;
      }

      if (submitBtn) {
        (submitBtn as HTMLButtonElement).disabled = true;
        submitBtn.querySelector('span')!.textContent = 'Creating account...';
      }

      // 2. Register via Supabase Client Auth
      const { data, error } = await supabase.auth.signUp({
        email,
        password,
        options: {
          data: {
            name: name
          }
        }
      });

      if (error) {
        if (errorMsg) errorMsg.textContent = error.message;
        errorAlert?.classList.remove('hidden');
        if (submitBtn) {
          (submitBtn as HTMLButtonElement).disabled = false;
          submitBtn.querySelector('span')!.textContent = 'Register Account';
        }
      } else {
        // Successful registration. Check if we redirect back to checkout or dashboard
        const urlParams = new URLSearchParams(window.location.search);
        const redirect = urlParams.get('redirect');
        if (redirect) {
          window.location.href = `/${redirect}`;
        } else {
          window.location.href = '/dashboard';
        }
      }
    });
  </script>
</Layout>
