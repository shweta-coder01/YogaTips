---
import Layout from '../layouts/Layout.astro';
const basePath = import.meta.env.BASE_URL;
---

<Layout title="Choose New Password" description="Enter a new secure password for your Global Yoga Tips account.">
  <section class="py-20 bg-primary-bg min-h-[calc(100vh-22rem)] flex items-center justify-center">
    <div class="max-w-md w-full mx-4">
      <div class="bg-white border border-border-main rounded-3xl p-8 sm:p-10 shadow-md space-y-6 relative overflow-hidden">
        
        <div class="text-center space-y-2">
          <h1 class="text-2xl sm:text-3xl font-heading font-semibold text-text-main">Set New Password</h1>
          <p class="text-text-secondary text-sm">Please choose a new secure password to secure your account access.</p>
        </div>

        <!-- Success Alert box -->
        <div id="success-alert" class="hidden bg-success-bg/10 border border-success-sage/20 text-success-sage text-xs font-semibold rounded-2xl p-5 space-y-2">
          <div class="flex items-center space-x-2">
            <svg class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="font-bold text-sm">Password Updated</span>
          </div>
          <p class="text-[11px] text-text-secondary font-normal leading-relaxed">
            Your password has been successfully updated. Redirecting you to your user dashboard...
          </p>
        </div>

        <!-- Error Alert box -->
        <div id="error-alert" class="hidden bg-[#FDF2F2] border border-[#FDE8E8] text-[#E53E3E] text-xs font-semibold rounded-2xl p-4 flex items-start space-x-2.5">
          <svg class="h-4.5 w-4.5 shrink-0" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          <span id="error-message">Error updating password. Try requesting a new link.</span>
        </div>

        <!-- Form -->
        <form id="reset-password-form" class="space-y-4">
          <!-- Password -->
          <div class="space-y-1.5 relative">
            <label for="new-password" class="text-xs uppercase font-bold text-text-secondary tracking-wider">New Password</label>
            <input 
              type="password" 
              id="new-password" 
              required 
              placeholder="Min 6 characters" 
              class="w-full bg-primary-bg border border-border-main rounded-2xl py-3 px-4 text-sm text-text-main focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
            />
          </div>

          <!-- Confirm Password -->
          <div class="space-y-1.5 relative">
            <label for="confirm-password" class="text-xs uppercase font-bold text-text-secondary tracking-wider">Confirm Password</label>
            <input 
              type="password" 
              id="confirm-password" 
              required 
              placeholder="Re-type password" 
              class="w-full bg-primary-bg border border-border-main rounded-2xl py-3 px-4 text-sm text-text-main focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-all"
            />
          </div>

          <!-- Submit Button -->
          <button 
            type="submit" 
            id="submit-btn"
            class="w-full btn-primary py-3.5 rounded-full text-sm font-semibold tracking-wider flex items-center justify-center space-x-2 cursor-pointer shadow-sm"
          >
            <span>Update Password</span>
            <svg class="h-4.5 w-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Client-side Logic -->
  <script>
    import { supabase } from '../lib/supabase.js';

    const resetForm = document.getElementById('reset-password-form');
    const successAlert = document.getElementById('success-alert');
    const errorAlert = document.getElementById('error-alert');
    const errorMsg = document.getElementById('error-message');
    const submitBtn = document.getElementById('submit-btn');

    resetForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const password = (document.getElementById('new-password') as HTMLInputElement).value;
      const confirmPassword = (document.getElementById('confirm-password') as HTMLInputElement).value;

      if (password.length < 6) {
        if (errorMsg) errorMsg.textContent = 'Password must be at least 6 characters.';
        errorAlert?.classList.remove('hidden');
        return;
      }

      if (password !== confirmPassword) {
        if (errorMsg) errorMsg.textContent = 'Passwords do not match.';
        errorAlert?.classList.remove('hidden');
        return;
      }

      if (submitBtn) {
        (submitBtn as HTMLButtonElement).disabled = true;
        submitBtn.querySelector('span')!.textContent = 'Updating...';
      }

      successAlert?.classList.add('hidden');
      errorAlert?.classList.add('hidden');

      // Call Supabase update user password
      const { error } = await supabase.auth.updateUser({ password });

      if (error) {
        if (errorMsg) errorMsg.textContent = error.message;
        errorAlert?.classList.remove('hidden');
        if (submitBtn) {
          (submitBtn as HTMLButtonElement).disabled = false;
          submitBtn.querySelector('span')!.textContent = 'Update Password';
        }
      } else {
        successAlert?.classList.remove('hidden');
        resetForm.classList.add('hidden');
        
        setTimeout(() => {
          const basePath = document.body.dataset.baseUrl || '/';
          window.location.href = `${basePath}dashboard`;
        }, 2000);
      }
    });
  </script>
</Layout>
